---
// src/components/Projects.astro
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: string;
}

const { lang = "pt" } = Astro.props;
const t = useTranslations(lang as any);

const projects = [
  {
    title: t("proj.golden.title"),
    desc: t("proj.golden.desc"),
    tags: ["Python", "AWS", "QR Code"],
    category: "fullstack",
    link: "https://goldenparktag.com",
    github: "https://github.com/JeffSSC/goldenpark-tag",
  },
  {
    title: t("proj.extractor.title"),
    desc: t("proj.extractor.desc"),
    tags: ["Python", "AWS Lambda", "OCR"],
    category: "backend",
    link: "",
    github: "https://github.com/JeffSSC/extractor-nfe",
  },
  {
    title: t("proj.themis.title"),
    desc: t("proj.themis.desc"),
    tags: ["LangChain", "AWS", "Telegram"],
    category: "fullstack",
    link: "",
    github: "https://github.com/JeffSSC/themis-chatbot",
  },
  {
    title: t("proj.mikael.title"),
    desc: t("proj.mikael.desc"),
    tags: ["Python", "YOLO", "OpenCV"],
    category: "robotics",
    link: "",
    github: "https://github.com/JeffSSC/mikael-lerobot",
  },
  {
    title: t("proj.portfolio.title"),
    desc: t("proj.portfolio.desc"),
    tags: ["Astro", "TypeScript", "Three.js"],
    category: "frontend",
    link: "https://jeffsc.com.br",
    github: "https://github.com/JeffSSC/astro_portfolio",
  },
];
---

<section class="section projects" id="work">
  <div class="container">
    <div class="section-head">
      <span class="section-meta">
        <span class="num-sm mono">03</span>
        <h2 class="section-title serif">Work</h2>
      </span>
      <div class="filter-row" id="project-filters">
        <button class="filter on" data-filter="all">All</button>
        <button class="filter" data-filter="frontend">Frontend</button>
        <button class="filter" data-filter="backend">Backend</button>
        <button class="filter" data-filter="fullstack">Full-Stack</button>
        <button class="filter" data-filter="robotics">Robotics</button>
      </div>
    </div>
    
    <div class="proj-grid" id="projects-grid">
      {projects.map((proj) => (
        <article class="proj-card" data-category={proj.category}>
          <div class="proj-card-top">
            <span class="mono text-xs">{proj.category}</span>
          </div>
          <h3 class="proj-card-title serif">{proj.title}</h3>
          <p class="proj-card-sum">{proj.desc}</p>
          <div class="chips">
            {proj.tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
          <div class="proj-links">
            {proj.link && (
              <a href={proj.link} target="_blank" rel="noopener" class="proj-link">
                Live
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            )}
            {proj.github && (
              <a href={proj.github} target="_blank" rel="noopener" class="proj-link">
                GitHub
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.236 1.839 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.124-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.659 1.652.248 2.873.124 3.176.767.84 1.236 1.91 1.236 3.221 0 4.609-2.807 5.628-5.475 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 100px 0;
  }

  @media (max-width: 720px) {
    .projects {
      padding: 60px 0;
    }
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 60px;
  }

  @media (max-width: 860px) {
    .section-head {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .section-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .num-sm {
    color: var(--ink);
    font-weight: 500;
  }

  .section-title {
    font-size: clamp(38px, 6vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .text-xs {
    font-size: 11px;
  }

  .filter-row {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .filter {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--rule);
    font-size: 13px;
    font-family: var(--font-mono);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .filter:hover {
    border-color: var(--ink);
  }

  .filter.on {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }

  .proj-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  @media (max-width: 720px) {
    .proj-grid {
      grid-template-columns: 1fr;
    }
  }

  .proj-card {
    background: var(--bg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 320px;
  }

  .proj-card-top {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
  }

  .proj-card-title {
    font-size: 28px;
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .proj-card-sum {
    color: var(--ink-2);
    margin: 0;
    flex: 1;
    font-size: 15px;
    line-height: 1.55;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--rule);
    font-size: 12px;
    font-family: var(--font-mono);
    background: var(--card);
  }

  .proj-links {
    display: flex;
    gap: 16px;
    margin-top: auto;
  }

  .proj-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
  }

  .proj-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .proj-card.hidden {
    display: none;
  }
</style>

<script>
  const filterButtons = document.querySelectorAll('.filter');
  const projectCards = document.querySelectorAll('.proj-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      
      filterButtons.forEach(b => b.classList.remove('on'));
      btn.classList.add('on');
      
      projectCards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>