---
// src/components/Hero.astro
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: string;
}

const { lang = "pt" } = Astro.props;
const t = useTranslations(lang as any);

const heroName = t("hero.name");
const heroRole = t("hero.role");
const heroCta = t("hero.cta");

const location = lang === "pt" ? "Currently building on Peakerton" : "Currently building on Peakerton";
---

<section class="hero container" id="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-top">
    <div class="hero-meta">
      <span class="dot"></span>
      <span class="mono">{location}</span>
    </div>
    <div class="hero-meta right">
      <span class="mono">Joinville · BR · <span id="current-time"></span></span>
    </div>
  </div>
  
  <h1 class="hero-title serif">
    <span class="hero-line">Jefferson</span>
    <span class="hero-line">Silva <em>Caires.</em></span>
  </h1>
  
  <div class="hero-bottom">
    <div class="hero-role">
      <span class="mono">Currently —</span>
      <span class="serif role-text">{heroRole}</span>
    </div>
    <p class="hero-tagline">
      Building digital products with clean code and thoughtful design.
    </p>
    <div class="hero-cta">
      <a href="#work" class="btn-primary">View Work</a>
      <a href="#contact" class="btn-ghost">Contact Me</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 80px 40px 60px;
    min-height: 88vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    margin: 0 auto;
    max-width: 1320px;
    width: 100%;
  }

  @media (max-width: 720px) {
    .hero {
      padding: 40px 20px 40px;
      min-height: auto;
    }
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px),
      linear-gradient(90deg, var(--rule) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.3;
    mask-image: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), black 0%, transparent 60%);
    -webkit-mask-image: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), black 0%, transparent 60%);
    transition: opacity 0.4s;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 30px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero-meta.right {
    justify-content: flex-end;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px var(--accent-soft); }
    50% { box-shadow: 0 0 0 8px transparent; }
  }

.hero-title {
    font-size: clamp(80px, 16vw, 240px);
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin: 0;
    text-align: left;
  }

  .hero-line {
    display: block;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-bottom {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 48px;
    align-items: end;
    margin-top: 60px;
    padding-top: 30px;
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 860px) {
    .hero-bottom {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .hero-role {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero-role .mono {
    font-size: 12px;
    color: var(--muted);
  }

  .role-text {
    font-size: 22px;
  }

  .hero-tagline {
    max-width: 420px;
    color: var(--ink-2);
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    background: var(--ink);
    color: var(--bg);
    font-size: 14px;
    letter-spacing: -0.005em;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: var(--accent);
    color: var(--bg);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    border: 1px solid var(--rule);
    font-size: 14px;
    transition: border-color 0.2s, background 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--ink);
    background: var(--card);
  }

  @media (max-width: 720px) {
    .hero {
      padding: 40px 0 40px;
      min-height: auto;
    }
  }
</style>

<script>
  // Update mouse position for gradient mask effect
  const hero = document.getElementById("hero");
  const gridBg = hero?.querySelector(".hero-grid-bg") as HTMLElement;

  if (gridBg) {
    document.addEventListener("mousemove", (e) => {
      const x = (e.clientX / window.innerWidth) * 100;
      const y = (e.clientY / window.innerHeight) * 100;
      gridBg.style.setProperty("--mx", `${x}%`);
      gridBg.style.setProperty("--my", `${y}%`);
    });
  }

  // Update time
  function updateTime() {
    const timeEl = document.getElementById("current-time");
    if (timeEl) {
      const now = new Date();
      const options: Intl.DateTimeFormatOptions = { 
        timeZone: "America/Sao_Paulo",
        hour: "2-digit", 
        minute: "2-digit",
        hour12: true 
      };
      timeEl.textContent = now.toLocaleTimeString("en-US", options);
    }
  }
  
  updateTime();
  setInterval(updateTime, 60000);
</script>