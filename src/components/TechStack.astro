---
// src/components/TechStack.astro
import { useTranslations } from "../i18n/utils";
import { Icon } from "astro-icon/components";

interface Props {
  lang?: string;
}

const { lang = "pt" } = Astro.props;
const t = useTranslations(lang as any);

const techCategories = [
  {
    label: "Frontend",
    techs: [
      { icon: "simple-icons:astro", name: "Astro" },
      { icon: "simple-icons:vuedotjs", name: "Vue.js" },
      { icon: "simple-icons:html5", name: "HTML5" },
      { icon: "simple-icons:css3", name: "CSS3" },
      { icon: "simple-icons:tailwindcss", name: "Tailwind" },
      { icon: "simple-icons:typescript", name: "TypeScript" },
    ],
  },
  {
    label: "Backend",
    techs: [
      { icon: "simple-icons:python", name: "Python" },
      { icon: "simple-icons:nodedotjs", name: "Node.js" },
      { icon: "simple-icons:postgresql", name: "PostgreSQL" },
      { icon: "simple-icons:mysql", name: "MySQL" },
      { icon: "simple-icons:amazonaws", name: "AWS" },
    ],
  },
  {
    label: "Tools & DevOps",
    techs: [
      { icon: "simple-icons:git", name: "Git" },
      { icon: "simple-icons:github", name: "GitHub" },
      { icon: "simple-icons:docker", name: "Docker" },
      { icon: "simple-icons:figma", name: "Figma" },
    ],
  },
];

const certifications = [
  { name: "AWS AI Practitioner", year: "2024" },
  { name: "AWS Cloud Practitioner", year: "2024" },
];
---

<section class="section stack" id="stack">
  <div class="container">
    <div class="section-head">
      <span class="section-meta">
        <span class="num-sm mono">04</span>
        <h2 class="section-title serif">{t("tech.title")}</h2>
      </span>
    </div>
    
    <div class="stack-grid">
      {techCategories.map((category) => (
        <div class="stack-col">
          <span class="stack-label mono">{category.label}</span>
          <div class="chips">
            {category.techs.map((tech) => (
              <span class="chip">
                <span class="chip-dot"></span>
                {tech.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <div class="certs-section">
      <span class="stack-label mono">{t("tech.certs")}</span>
      <div class="certs">
        {certifications.map((cert) => (
          <div class="cert">
            <div class="cert-badge">
              <span class="cert-ring"></span>
              <span class="serif">{cert.year.slice(-2)}</span>
            </div>
            <div>
              <div class="cert-name">{cert.name}</div>
              <div class="cert-meta mono">AWS</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .stack {
    padding: 100px 0;
  }

  @media (max-width: 720px) {
    .stack {
      padding: 60px 0;
    }
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 60px;
  }

  @media (max-width: 860px) {
    .section-head {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .section-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .num-sm {
    color: var(--ink);
    font-weight: 500;
  }

  .section-title {
    font-size: clamp(38px, 6vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    margin-bottom: 60px;
  }

  @media (max-width: 860px) {
    .stack-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .stack-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .stack-label {
    color: var(--muted);
    font-size: 12px;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--rule);
    background: var(--card);
    font-size: 13px;
    font-family: var(--font-mono);
    transition: border-color 0.2s, background 0.2s;
  }

  .chip:hover {
    border-color: var(--ink);
  }

  .chip-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  .certs-section {
    margin-top: 40px;
  }

  .certs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    max-width: 600px;
  }

  @media (max-width: 520px) {
    .certs {
      grid-template-columns: 1fr;
    }
  }

  .cert {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    align-items: center;
    padding: 16px;
    border: 1px solid var(--rule);
    background: var(--card);
  }

  .cert-badge {
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    background: var(--bg);
    border: 1px solid var(--rule);
    position: relative;
  }

  .cert-ring {
    position: absolute;
    inset: 6px;
    border: 1px dashed var(--accent);
    border-radius: 50%;
    animation: spin 18s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .cert-badge .serif {
    font-size: 18px;
    position: relative;
    z-index: 1;
  }

  .cert-name {
    font-size: 18px;
  }

  .cert-meta {
    margin-top: 2px;
    color: var(--muted);
    font-size: 12px;
  }
</style>