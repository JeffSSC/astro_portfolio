---
// src/components/LanguageSwitcher.astro
---

<div class="lang-switch" id="lang-switch">
  <button type="button" data-lang="en" class="lang-btn">EN</button>
  <button type="button" data-lang="pt" class="lang-btn">PT</button>
</div>

<style>
  .lang-switch {
    display: flex;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .lang-btn {
    padding: 2px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    transition: color 0.2s;
  }

  .lang-btn:hover {
    color: var(--ink);
  }

  .lang-btn.on {
    color: var(--ink);
  }
</style>

<script>
  const container = document.getElementById("lang-switch");
  const buttons = container?.querySelectorAll(".lang-btn");

  function getStoredLang(): string {
    return localStorage.getItem("lang") || "en";
  }

  function updateButtons() {
    const currentLang = getStoredLang();
    buttons?.forEach((btn) => {
      const lang = (btn as HTMLElement).dataset.lang;
      btn.classList.toggle("active", lang === currentLang);
    });
  }

  buttons?.forEach((btn) => {
    btn.addEventListener("click", () => {
      const lang = (btn as HTMLElement).dataset.lang;
      if (lang) {
        localStorage.setItem("lang", lang);
        updateButtons();
      }
    });
  });

  updateButtons();
</script>
