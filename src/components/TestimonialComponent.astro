---
// src/components/TestimonialComponent.astro
import { useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";

interface Props {
  lang?: string;
}

const { lang = "pt" } = Astro.props;
const t = useTranslations(lang as any);

const testimonials = t("testimonials") as any[];

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/*.{jpeg,jpg,png,gif}",
);
---

<section class="section testimonials" id="testimonials">
  <div class="container">
    <div class="section-head">
      <span class="section-meta">
        <span class="num-sm mono">05</span>
        <h2 class="section-title serif">{t("testimonials.title")}</h2>
      </span>
    </div>
    
    <div class="testimonial-slider" id="testimonial-slider">
      {testimonials.map((testimonial, index) => (
        <div class="testimonial-slide">
          <blockquote class="quote">
            <span class="quote-mark" aria-hidden="true">"</span>
            <p class="quote-text serif">{testimonial.text}</p>
            <footer class="quote-foot">
              <div class="quote-avatar">
                {testimonial.avatar && images[testimonial.avatar] ? (
                  <Image 
                    src={images[testimonial.avatar]()} 
                    alt={testimonial.author}
                    width={48}
                    height={48}
                    class="avatar-img"
                  />
                ) : (
                  <span class="avatar-initials">{testimonial.author.charAt(0)}</span>
                )}
              </div>
              <div>
                <div class="quote-name">{testimonial.author}</div>
                <div class="quote-role mono">{testimonial.role}</div>
              </div>
            </footer>
          </blockquote>
        </div>
      ))}
    </div>
    
    <div class="quote-nav">
      <button class="nav-btn" id="testimonial-prev" aria-label="Previous testimonial">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 12L4 12M9 6L4.707 10.293C4.374 10.626 4.207 10.793 4.207 11C4.207 11.207 4.374 11.374 4.707 11.707L9 16"/>
        </svg>
      </button>
      <button class="nav-btn" id="testimonial-next" aria-label="Next testimonial">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 12L20 12M15 18L19.293 13.707C19.626 13.374 19.793 13.207 19.793 13C19.793 12.793 19.626 12.626 19.293 12.293L15 8"/>
        </svg>
      </button>
    </div>
    
    <div class="quote-dots" id="testimonial-dots">
      {testimonials.map((_, i) => (
        <button class="dot-btn" data-index={i} aria-label={`Go to testimonial ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 100px 0;
  }

  @media (max-width: 720px) {
    .testimonials {
      padding: 60px 0;
    }
  }

  .container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .section-head {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 60px;
  }

  @media (max-width: 860px) {
    .section-head {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }

  .section-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .num-sm {
    color: var(--ink);
    font-weight: 500;
  }

  .section-title {
    font-size: clamp(38px, 6vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .testimonial-slider {
    max-width: 900px;
    margin: 0 auto;
  }

  .quote {
    position: relative;
    margin: 0;
    padding: 40px 0 40px 60px;
    animation: quoteIn 0.6s cubic-bezier(0.22, 0.8, 0.2, 1);
  }

  @keyframes quoteIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 720px) {
    .quote {
      padding: 20px 0 20px 40px;
    }
  }

  .quote-mark {
    position: absolute;
    left: 0;
    top: 10px;
    font-size: 140px;
    line-height: 0.7;
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .quote-mark {
      font-size: 80px;
    }
  }

  .quote-text {
    font-size: clamp(24px, 3vw, 34px);
    line-height: 1.32;
    margin: 0 0 30px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .quote-foot {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .quote-avatar {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    background: var(--card);
    border: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--ink);
    border-radius: 50%;
    overflow: hidden;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-initials {
    font-family: var(--font-mono);
    font-size: 18px;
  }

  .quote-name {
    font-size: 18px;
    font-weight: 500;
  }

  .quote-role {
    font-size: 14px;
    color: var(--muted);
  }

  .quote-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 30px;
  }

  .nav-btn {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 1px solid var(--rule);
    background: transparent;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .nav-btn:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--bg);
  }

  .quote-dots {
    margin-top: 20px;
    display: flex;
    justify-content: center;
    gap: 8px;
  }

  .dot-btn {
    width: 24px;
    height: 4px;
    background: var(--rule);
    border: none;
    cursor: pointer;
    transition: background 0.2s, width 0.3s;
  }

  .dot-btn.active,
  .dot-btn:hover {
    background: var(--ink);
  }
</style>

<script>
  const slider = document.getElementById("testimonial-slider");
  const prevBtn = document.getElementById("testimonial-prev");
  const nextBtn = document.getElementById("testimonial-next");
  const dots = document.querySelectorAll(".dot-btn");
  
  if (slider && prevBtn && nextBtn) {
    const slides = slider.querySelectorAll(".testimonial-slide");
    let currentIndex = 0;
    
    function showSlide(index) {
      slides.forEach((slide, i) => {
        (slide as HTMLElement).style.display = i === index ? "block" : "none";
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("active", i === index);
      });
      currentIndex = index;
    }
    
    showSlide(0);
    
    prevBtn.addEventListener("click", () => {
      const newIndex = (currentIndex - 1 + slides.length) % slides.length;
      showSlide(newIndex);
    });
    
    nextBtn.addEventListener("click", () => {
      const newIndex = (currentIndex + 1) % slides.length;
      showSlide(newIndex);
    });
    
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => showSlide(i));
    });
  }
</script>