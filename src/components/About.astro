---
import { getData, type DataLang } from "../i18n/data";

interface Props {
  lang: DataLang;
}

const { lang } = Astro.props;
const data = getData(lang);
---
<section id="about" class="py-24 md:py-14">
  <header class="reveal in grid md:grid-cols-[1fr_2fr_1fr] gap-4 md:gap-10 items-end mb-14">
    <div class="flex flex-col gap-1">
      <span class="mono text-ink">00</span>
      <span class="mono">{lang === "pt" ? "Índice · Sobre" : "Index · About"}</span>
    </div>
    <h2 class="serif m-0 tracking-[-0.03em] leading-[1.02] mb-2 min-w-max" style="font-size: clamp(38px, 6vw, 72px);">
      {lang === "pt" ? "Engenharia pragmática" : "Pragmatic engineering"}<br />
      <span class="quiet">{lang === "pt" ? "sob medida, tipada e testada." : "measured, typed and tested."}</span>
    </h2>
  </header>
  <div class="grid md:grid-cols-[1fr_360px] gap-15 md:gap-8">
    <div>
      {data.about.map((p: string) => (
        <p class="serif text-[28px] leading-[1.32] m-0 mb-4 max-w-[720px] text-pretty">{p}</p>
      ))}
    </div>
    <aside class="self-start md:sticky md:top-24">
      <dl class="m-0 grid grid-cols-[90px_1fr] gap-x-5 gap-y-3.5 p-6 border border-rule bg-card">
        <dt class="mono">{lang === "pt" ? "Baseado em" : "Based in"}</dt>
        <dd class="m-0 text-sm">{data.location}</dd>
        <dt class="mono">{lang === "pt" ? "Foco" : "Focus"}</dt>
        <dd class="m-0 text-sm">{lang === "pt" ? "Full-stack · IA Aplicada · Cloud" : "Full-stack · Applied AI · Cloud"}</dd>
        <dt class="mono">{lang === "pt" ? "Escreve" : "Writes"}</dt>
        <dd class="m-0 text-sm">Python · TypeScript · SQL</dd>
        <dt class="mono">{lang === "pt" ? "Fala" : "Speaks"}</dt>
        <dd class="m-0 text-sm">{lang === "pt" ? "Português · Inglês" : "Portuguese · English"}</dd>
        <dt class="mono">{lang === "pt" ? "Certs" : "Certs"}</dt>
        <dd class="m-0 text-sm">AWS AI · AWS CP</dd>
      </dl>
    </aside>
  </div>
</section>
