---
import { getData, type DataLang } from "../i18n/data";

interface Props {
  lang: DataLang;
}

const { lang } = Astro.props;
const data = getData(lang);
---
<section id="experience" class="py-24 md:py-14 mb-8 md:mb-12">
  <header class="grid md:grid-cols-[1fr_2fr_1fr] gap-10 items-end mb-14">
    <div class="flex flex-col gap-1">
      <span class="mono text-ink">02</span>
      <span class="mono">{lang === "pt" ? "Índice · Experiência" : "Index · Experience"}</span>
    </div>
    <h2 class="serif m-0 tracking-[-0.03em] leading-[1.02]" style="font-size: clamp(38px, 6vw, 72px);">
      {lang === "pt" ? "Onde entreguei." : "Where I've shipped."}
    </h2>
  </header>
  <ol class="list-none p-0 m-0 grid gap-20 md:gap-15">
    {data.experience.map((e, idx) => (
      <li class={`grid md:grid-cols-[200px_1fr] gap-12 pt-7 ${idx === 0 ? "" : "border-t border-rule"}`}>
        <div class="flex flex-col gap-1">
          <span class="serif text-[72px] leading-none tracking-[-0.03em]">{e.year}</span>
          <span class="mono">{e.duration}</span>
        </div>
        <div>
          <div class="flex flex-wrap justify-between gap-4 items-baseline mb-5">
            <h3 class="serif m-0 text-[40px] leading-[1.05] tracking-[-0.02em]">{e.company}</h3>
            <div class="mono flex gap-2 text-muted">
              <span>{e.role}</span>
              <span class="text-rule">·</span>
              <span>{e.mode}</span>
            </div>
          </div>
          <ul class="list-none p-0 m-0 grid gap-3">
            {e.bullets.map((b: string, j: number) => (
              <li class="grid grid-cols-[30px_1fr] gap-3.5 items-baseline max-w-[640px] text-ink-2 text-[15px] leading-[1.55]">
                <span class="mono text-muted">{String(j + 1).padStart(2, "0")}</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </li>
    ))}
  </ol>
</section>
