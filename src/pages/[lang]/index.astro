---
import { Icon } from "astro-icon/components";

import PageLayout from "../../layouts/PageLayout.astro";
import Hero from "../../components/Hero.astro";
import About from "../../components/About.astro";
import Experience from "../../components/Experience.astro";
import Projects from "../../components/Projects.astro";
import TechStack from "../../components/TechStack.astro";
import TestimonialComponent from "../../components/TestimonialComponent.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import HomeAnimation from "../../components/HomeAnimation.astro";
import ScrambleText from "../../components/ScrambleText.astro";
import ScrollArrow from "../../components/ScrollArrow.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import SectionSubtitle from "../../components/ui/SectionSubtitle.astro";
import Text from "../../components/ui/Text.astro";
import CardProject from "../../components/CardProject.astro";
import ExpComponent from "../../components/ExpComponent.astro";

import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
    return [{ params: { lang: "pt" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang || "pt";
const t = useTranslations(lang as any);
const testimonials = t("testimonials");

const pageTitle = t("site.title");
const pageDescription = (t("about.text") as readonly string[])[0];

const whatsappMessage = encodeURIComponent(t("hero.whatsapp_msg"));
const whatsappLink = `https://wa.me/5547991158071?text=${whatsappMessage}`;
---

<PageLayout title={pageTitle} description={pageDescription}>
    <Hero lang={lang} />
    
    <div id="main-content">
        <About lang={lang} />
        
        <section id="about" class="about flex flex-col items-center">
            <div class="pt-8 flex flex-col max-w-5xl items-center">
                <SectionTitle data-aos="fade-up"
                    >{t("about.title")}</SectionTitle
                >
                <div
                    data-aos="fade-up"
                    class="flex flex-col max-w-5xl justify-center gap-4 p-4 pt-5 md:p-10 sm:ml-10 sm:mr-10 flex-wrap md:flex-nowrap"
                >
                    {
                        (t("about.text") as readonly string[]).map(
                            (paragraph) => (
                                <Text class="mb-4" set:html={paragraph} />
                            ),
                        )
                    }
                </div>
            </div>
        </section>
        <Experience lang={lang} />
        <section id="stack" class="technologies flex flex-col items-center">
            <div
                class="pt-8 flex flex-col items-center max-w-5xl"
                data-aos="fade-up"
            >
                <SectionTitle>{t("tech.title")}</SectionTitle>
                <div class="pt-8 flex flex-col items-center">
                    <SectionSubtitle>{t("tech.certs")}</SectionSubtitle>
                    <div class="flex flex-wrap gap-4 p-5 justify-center">
                        <div
                            data-aos="fade-right"
                            class="flex flex-col gap-2 items-center transition-transform hover:-translate-y-1"
                        >
                            <div class="bg-white rounded-lg shadow-lg">
                                <div
                                    data-iframe-width="300"
                                    data-iframe-height="240"
                                    data-share-badge-id="536e030f-489d-443b-9d28-03fbba352de4"
                                    data-share-badge-host="https://www.credly.com"
                                >
                                </div>
                            </div>
                            <Text>AWS Cloud Practitioner</Text>
                        </div>
                        <div
                            data-aos="fade-left"
                            class="flex flex-col gap-2 items-center transition-transform hover:-translate-y-1"
                        >
                            <div class="bg-white rounded-lg shadow-lg">
                                <div
                                    data-iframe-width="300"
                                    data-iframe-height="240"
                                    data-share-badge-id="62403a74-4357-43b0-93e9-07f0dacc7007"
                                    data-share-badge-host="https://www.credly.com"
                                >
                                </div>
                            </div>

                            <Text>AWS AI Practitioner</Text>
                        </div>
                    </div>
                    <script
                        type="text/javascript"
                        async
                        src="//cdn.credly.com/assets/utilities/embed.js"
                    ></script>
                </div>
                <SectionSubtitle>{t("tech.stack")}</SectionSubtitle>
                <TechStack
                    techs={[
                        "vuejs",
                        { name: "Tailwind", icon: "tailwindcss" },
                        "python",
                        "django",
                        "postgresql",
                        { icon: "amazonwebservices", name: "AWS" },
                        "docker",
                    ]}
                />
                <SectionSubtitle>{t("tech.exp")}</SectionSubtitle>
                <TechStack
                    techs={[
                        "nodejs",
                        "mysql",
                        "nginx",
                        "jupyter",
                        "astro",
                        "linux",
                        "react",
                    ]}
                />
            </div>
        </section>
        <section id="testimonials" class="testimonials flex flex-col items-center w-full">
            <div
                class="pt-8 flex flex-col items-center w-full max-w-5xl"
                data-aos="fade-in-up"
            >
                <SectionTitle>{t("testimonials.title")}</SectionTitle>
                <TestimonialComponent testimonials={testimonials as any} />
            </div>
        </section>
    </div>
    <div
        id="projects-contact-content"
        class="opacity-0 transition-opacity duration-1000 ease-in-out"
    >
        <Projects lang={lang} />
        <TechStack lang={lang} />
        <TestimonialComponent lang={lang} />
        <Contact lang={lang} />
    </div>
    <Footer lang={lang} />
</PageLayout>

<style is:global>
    header {
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    body.loaded header,
    body.loaded #landing-content,
    body.loaded #main-content,
    body.loaded #projects-contact-content {
        opacity: 1;
    }
</style>

<script>
    function showContent() {
        setTimeout(() => {
            document.body.classList.add("loaded");
        }, 1000);
    }

    window.addEventListener("home-animation-ready", showContent);
    setTimeout(showContent, 4000);
</script>
